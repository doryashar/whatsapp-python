# WhatsApp API Configuration
DATABASE_URL=postgres://user:password@host:5432/dbname
API_KEY=your-api-key-here

# Admin Dashboard Configuration
ADMIN_PASSWORD=your-secure-admin-password

# Grafana Configuration
GRAFANA_PASSWORD=admin

# Connection Health Check Configuration
# How often to check connection health (seconds)
HEALTH_CHECK_INTERVAL_SECONDS=30
# Timeout for health check queries (seconds)
HEALTH_CHECK_TIMEOUT_SECONDS=10
# Number of consecutive failures before marking tenant as disconnected
MAX_HEALTH_CHECK_FAILURES=3

# Bridge Auto-Restart Configuration
# Enable automatic restart of crashed bridge processes
AUTO_RESTART_BRIDGE=true
# Maximum restart attempts within the restart window
MAX_RESTART_ATTEMPTS=3
# Time window for counting restart attempts (seconds)
RESTART_WINDOW_SECONDS=300
# Cooldown period between restart attempts (seconds)
RESTART_COOLDOWN_SECONDS=10
